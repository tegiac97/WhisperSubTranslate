{
  "name": "whispersubtranslate",
  "version": "1.4.0",
  "main": "main.js",
  "scripts": {
    "start": "electron --expose-gc .",
    "start:api": "node api-server.js",
    "build": "electron-builder --publish never",
    "build-win": "electron-builder --win",
    "postinstall": "node scripts/postinstall.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint *.js locales/*.js --fix",
    "format": "prettier --write \"*.js\" \"locales/*.js\" \"*.json\" \"*.html\" \"*.css\""
  },
  "keywords": [],
  "author": "GTPS Team",
  "license": "GPL-3.0",
  "description": "Whisper 기반 자막 추출·번역 도구 (whisper.cpp)",
  "build": {
    "appId": "com.whispersubtranslate.app",
    "productName": "WhisperSubTranslate",
    "directories": {
      "output": "dist2"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "locales/i18n.js",
      "renderer.js",
      "translator-enhanced.js",
      "myMemoryTranslator.js"
    ],
    "extraResources": [
      {
        "from": "whisper-cpp",
        "to": "whisper-cpp"
      },
      {
        "from": "nya.wav",
        "to": "nya.wav"
      },
      {
        "from": "ffprobe.exe",
        "to": "ffprobe.exe"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhisperSubTranslate"
    }
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "deepl-node": "^1.13.0",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "multer": "^1.4.5-lts.2"
  }
}
